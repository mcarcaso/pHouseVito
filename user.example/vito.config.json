{
  "bot": {
    "name": "Assistant"
  },
  "settings": {
    "harness": "pi-coding-agent",
    "streamMode": "final",
    "traceMessageUpdates": false,
    "currentContext": {
      "limit": 30,
      "includeThoughts": false,
      "includeTools": false,
      "includeArchived": false
    },
    "crossContext": {
      "limit": 3,
      "includeThoughts": false,
      "includeTools": false,
      "includeArchived": false,
      "maxSessions": 5
    },
    "requireMention": false,
    "memory": {
      "recalledMemoryLimit": 5,
      "profileUpdateContext": 2
    }
  },
  "harnesses": {
    "claude-code": {
      "model": "sonnet",
      "permissionMode": "bypassPermissions"
    },
    "pi-coding-agent": {
      "model": {
        "provider": "openrouter",
        "name": "minimax/minimax-m2.7"
      }
    }
  },
  "sessions": {},
  "channels": {
    "dashboard": {
      "enabled": true
    },
    "telegram": {
      "enabled": false,
      "allowedChatIds": []
    },
    "discord": {
      "enabled": false,
      "allowedGuildIds": [],
      "allowedChannelIds": [],
      "requireMention": false
    }
  },
  "cron": {
    "jobs": []
  }
}
