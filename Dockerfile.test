FROM node:20-slim

# Install curl for testing
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy everything needed
COPY package*.json ./
COPY bin/ ./bin/
COPY dist/ ./dist/
COPY templates/ ./templates/
COPY user.example/ ./user.example/

# Install dependencies (production only)
RUN npm install --omit=dev

# Create test user
RUN useradd -m testuser
USER testuser
WORKDIR /home/testuser

# Test script
CMD ["/bin/bash", "-c", "\
  echo '=== Vito CLI Test ===' && \
  echo '' && \
  echo '=== Testing vito init ===' && \
  node /app/bin/vito.js init -d /home/testuser/vito && \
  echo '' && \
  echo '=== Workspace created ===' && \
  ls -la /home/testuser/vito && \
  echo '' && \
  echo '=== Config ===' && \
  cat /home/testuser/vito/vito.config.json && \
  echo '' && \
  echo '=== Starting server ===' && \
  cd /app && \
  export VITO_WORKSPACE=/home/testuser/vito && \
  export PORT=3100 && \
  node dist/index.js &\
  SERVER_PID=$! && \
  echo \"Server PID: $SERVER_PID\" && \
  sleep 3 && \
  echo '' && \
  echo '=== Checking if server is alive ===' && \
  if kill -0 $SERVER_PID 2>/dev/null; then \
    echo \"✅ Server is running!\" && \
    echo '' && \
    echo '=== Testing API ===' && \
    curl -s http://localhost:3100/api/config | head -20 || echo 'API call failed'; \
  else \
    echo \"❌ Server crashed\"; \
    wait $SERVER_PID; \
  fi && \
  echo '' && \
  echo '=== Test complete ===' \
"]
