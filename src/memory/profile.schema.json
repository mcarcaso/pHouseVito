{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UserProfile",
  "description": "Structured user profile — the semantic memory layer. Small enough to always inject into the system prompt. Contains who the user is, their people, preferences, and key facts. Updated passively as conversations reveal new information.",
  "type": "object",
  "properties": {
    "basics": {
      "type": "object",
      "description": "Core identity — name, contact, location",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "timezone": { "type": "string" },
        "location": { "type": "string" },
        "faith": { "type": "string" }
      },
      "additionalProperties": false
    },
    "people": {
      "type": "array",
      "description": "Important people — family, friends, partner, colleagues",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "relation": { "type": "string" },
          "email": { "type": "string" },
          "phone": { "type": "string" },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["name", "relation"],
        "additionalProperties": false
      }
    },
    "interests": {
      "type": "array",
      "description": "Hobbies, passions, things they follow",
      "items": {
        "type": "object",
        "properties": {
          "topic": { "type": "string" },
          "level": { "type": "string", "enum": ["obsessed", "active", "casual", "learning"] },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["topic"],
        "additionalProperties": false
      }
    },
    "preferences": {
      "type": "object",
      "description": "How they want their AI to behave — communication style, code patterns, design choices",
      "properties": {
        "communication": {
          "type": "array",
          "items": { "type": "string" }
        },
        "code": {
          "type": "array",
          "items": { "type": "string" }
        },
        "design": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "work": {
      "type": "object",
      "description": "Professional life",
      "properties": {
        "employer": { "type": "string" },
        "role": { "type": "string" },
        "side_projects": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "notes": {
      "type": "array",
      "description": "Freeform key-value pairs for anything that doesn't fit a typed field — tickers, strategies, food preferences, entertainment, active programs, etc.",
      "items": {
        "type": "object",
        "properties": {
          "key": { "type": "string" },
          "value": { "type": "string" }
        },
        "required": ["key", "value"],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
