{
  "name": "personal-ai",
  "version": "0.1.0",
  "description": "Your personal AI assistant — runs locally, remembers everything, extends with skills",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ai": "./bin/vito.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run build:server && npm run build:dashboard",
    "build:server": "tsc",
    "build:dashboard": "cd dashboard && npm run build",
    "start": "node dist/server.js",
    "package": "npm run build && node scripts/package.js"
  },
  "keywords": [
    "ai",
    "assistant",
    "claude",
    "personal-ai",
    "automation"
  ],
  "author": "Mike Carcasole",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.54.0",
    "@mariozechner/pi-coding-agent": "latest",
    "@types/http-proxy": "^1.17.17",
    "ajv": "^8.18.0",
    "axios": "^1.13.5",
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0",
    "cors": "^2.8.6",
    "cron-schedule": "^6.0.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "execa": "^9.6.1",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "grammy": "^1.40.0",
    "gray-matter": "^4.0.3",
    "http-proxy": "^1.18.1",
    "openai": "^4.104.0",
    "playwright": "^1.58.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.13",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist/",
    "bin/",
    "skills/",
    "templates/",
    "README.md"
  ]
}
