{
  "bot": {
    "name": "Assistant"
  },
  "settings": {
    "harness": "pi-coding-agent",
    "streamMode": "final",
    "traceMessageUpdates": false,
    "currentContext": {
      "limit": 30,
      "includeThoughts": false,
      "includeTools": false,
      "includeArchived": false
    },
    "crossContext": {
      "limit": 3,
      "includeThoughts": false,
      "includeTools": false,
      "includeArchived": false,
      "maxSessions": 5
    },
    "requireMention": false,
    "memory": {
      "recalledMemoryLimit": 5,
      "profileUpdateContext": 2
    },
    "auto": {
      "pi-coding-agent": {
        "model": true,
        "modelChoices": [
          {
            "provider": "openrouter",
            "name": "deepseek/deepseek-v4-flash",
            "description": "Quick lane. Simple Q&A, formatting, short rewrites, lightweight classification, low-risk tasks, and other easy asks. Avoid for complex debugging, deep investigations, or multi-step tool chains."
          },
          {
            "provider": "openrouter",
            "name": "deepseek/deepseek-v4-pro",
            "description": "Default. Coding, debugging, tool chains, investigations, multimodal tasks, analysis, writing, and most real work."
          },
          {
            "provider": "openrouter",
            "name": "moonshotai/kimi-k2.6",
            "description": "Multimodal only. Images and PDFs. For vision-heavy jobs, use this lane; otherwise prefer Flash or Pro."
          }
        ]
      },
      "classifierModel": {
        "provider": "openrouter",
        "name": "deepseek/deepseek-v4-flash"
      },
      "currentContext": {
        "limit": true,
        "includeWorkingContext": true
      },
      "crossContext": {
        "limit": true,
        "maxSessions": true,
        "includeWorkingContext": true
      },
      "memory": {
        "recalledMemoryLimit": true
      },
      "classifierContext": {
        "currentSessionMessages": 25,
        "crossSessionMessages": 0,
        "crossSessionMaxSessions": 0
      }
    }
  },
  "harnesses": {
    "pi-coding-agent": {
      "model": {
        "provider": "openrouter",
        "name": "deepseek/deepseek-v4-pro"
      },
      "thinkingLevel": "off"
    }
  },
  "sessions": {
    "system:profile-updater": {
      "harness": "pi-coding-agent",
      "pi-coding-agent": {
        "model": {
          "provider": "openrouter",
          "name": "deepseek/deepseek-v4-flash"
        },
        "thinkingLevel": "off"
      }
    }
  },
  "channels": {
    "dashboard": {
      "enabled": true
    },
    "telegram": {
      "enabled": false,
      "allowedChatIds": []
    },
    "discord": {
      "enabled": false,
      "allowedGuildIds": [],
      "allowedChannelIds": [],
      "requireMention": false
    }
  },
  "cron": {
    "jobs": []
  }
}