{
  "bot": {
    "name": "Assistant"
  },
  "apps": {
    "baseDomain": "localhost",
    "portStart": 3100
  },
  "settings": {
    "harness": "pi-coding-agent",
    "streamMode": "final",
    "traceMessageUpdates": false,
    "requireMention": false,
    "timezone": "America/Toronto"
  },
  "harnesses": {
    "pi-coding-agent": {
      "model": {
        "provider": "openrouter",
        "name": "deepseek/deepseek-v4-flash"
      },
      "thinkingLevel": "medium"
    }
  },
  "sessions": {},
  "channels": {
    "dashboard": {
      "enabled": true
    },
    "telegram": {
      "enabled": false,
      "allowedChatIds": []
    },
    "discord": {
      "enabled": false,
      "allowedGuildIds": [],
      "allowedChannelIds": []
    }
  },
  "cron": {
    "jobs": []
  }
}
