{
  "bot": {
    "name": "Assistant"
  },
  "settings": {
    "harness": "pi-coding-agent",
    "streamMode": "final",
    "traceMessageUpdates": false,
    "currentContext": {
      "limit": 30,
      "includeThoughts": false,
      "includeTools": false,
      "includeArchived": false
    },
    "crossContext": {
      "limit": 3,
      "includeThoughts": false,
      "includeTools": false,
      "includeArchived": false,
      "maxSessions": 5
    },
    "requireMention": false,
    "memory": {
      "recalledMemoryLimit": 5,
      "profileUpdateContext": 2
    },
    "auto": {
      "pi-coding-agent": {
        "model": true,
        "modelChoices": [
          {
            "provider": "openrouter",
            "name": "minimax/minimax-m2.7",
            "description": "Default. Everything text — Q&A, coding, terminal, reasoning, writing, analysis, text files. No images or PDFs."
          },
          {
            "provider": "openrouter",
            "name": "moonshotai/kimi-k2.5",
            "description": "Multimodal only. Images and PDFs. For text files, use MiniMax instead."
          },
          {
            "provider": "openrouter",
            "name": "anthropic/claude-opus-4.6",
            "description": "Hard tasks. Last resort for complex debugging, architecture, or multi-step problems."
          }
        ]
      },
      "classifierModel": {
        "provider": "openrouter",
        "name": "google/gemini-3.1-flash-lite-preview"
      },
      "currentContext": {
        "limit": true,
        "includeWorkingContext": true
      },
      "crossContext": {
        "limit": true,
        "maxSessions": true,
        "includeWorkingContext": true
      },
      "memory": {
        "recalledMemoryLimit": true
      },
      "classifierContext": {
        "currentSessionMessages": 25,
        "crossSessionMessages": 0,
        "crossSessionMaxSessions": 0
      }
    }
  },
  "harnesses": {
    "pi-coding-agent": {
      "model": {
        "provider": "openrouter",
        "name": "minimax/minimax-m2.7"
      },
      "thinkingLevel": "off"
    }
  },
  "sessions": {},
  "channels": {
    "dashboard": {
      "enabled": true
    },
    "telegram": {
      "enabled": false,
      "allowedChatIds": []
    },
    "discord": {
      "enabled": false,
      "allowedGuildIds": [],
      "allowedChannelIds": [],
      "requireMention": false
    }
  },
  "cron": {
    "jobs": []
  }
}
