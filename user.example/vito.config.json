{
  "bot": {
    "name": "Assistant"
  },
  "settings": {
    "harness": "pi-coding-agent",
    "streamMode": "stream",
    "traceMessageUpdates": false,
    "currentContext": {
      "limit": 100,
      "includeThoughts": true,
      "includeTools": true,
      "includeArchived": false
    },
    "crossContext": {
      "limit": 5,
      "includeThoughts": false,
      "includeTools": false,
      "includeArchived": false
    }
  },
  "harnesses": {
    "claude-code": {
      "model": "sonnet",
      "permissionMode": "bypassPermissions"
    },
    "pi-coding-agent": {
      "model": {
        "provider": "openrouter",
        "name": "google/gemini-3-flash-preview"
      }
    }
  },
  "sessions": {
    "system:profile-updater": {
      "harness": "pi-coding-agent",
      "pi-coding-agent": {
        "model": {
          "provider": "openrouter",
          "name": "openai/gpt-5-nano"
        },
        "thinkingLevel": "off"
      }
    }
  },
  "channels": {
    "dashboard": {
      "enabled": true
    },
    "telegram": {
      "enabled": false,
      "allowedChatIds": []
    },
    "discord": {
      "enabled": false,
      "allowedGuildIds": [],
      "allowedChannelIds": [],
      "requireMention": false
    }
  },
  "cron": {
    "jobs": []
  }
}
